# ############################################################
# SciGate - VERCEL (Frontend) ENVIRONMENT VARIABLES
# ############################################################

# Your Render Backend URL (example: https://scigate-api.onrender.com)
NEXT_PUBLIC_SERVER_URL=

# Your RAG Service URL (Must be a public URL)
NEXT_PUBLIC_RAG_URL=

# World ID Staging App ID (from developer.world.org)
NEXT_PUBLIC_WORLD_APP_ID=

# Custom action ID created in Developer Portal
NEXT_PUBLIC_WORLD_ACTION_ID=

# The wallet address where you receive royalties
NEXT_PUBLIC_PAY_TO_ADDRESS=

# The PaperRegistry contract address on World Chain Sepolia
NEXT_PUBLIC_PAPER_REGISTRY_ADDRESS=
