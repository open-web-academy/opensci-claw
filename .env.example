# ===========================================================
# SciGate MVP — Environment Variables
# Copy this file to .env and fill in your values
# ===========================================================

# ── Wallet / Blockchain ─────────────────────────────────────
# Wallet private key for deploying contracts (NEVER commit this!)
PRIVATE_KEY=0x_your_private_key_here

# Wallet address that receives x402 payments (your earnings wallet)
PAY_TO_ADDRESS=0xc813c372D8123C1D8727d37f037F5a25f2173826

# World Chain testnet RPC (public endpoint, no key needed)
WORLD_CHAIN_RPC=https://worldchain-sepolia.g.alchemy.com/public

# PaperRegistry contract address (fill after deploying)
PAPER_REGISTRY_ADDRESS=0x_fill_after_deploy

# ── World ID ────────────────────────────────────────────────
# Get from https://developer.world.org → Your App → App ID
WORLD_APP_ID=app_963cce5506aa7a8897060b8b948eab7b

# Custom action for author verification (create in Developer Portal)
WORLD_ACTION_ID=verify-author

# ── RAG Engine (Google Gemini - FREE TIER) ────────────────────
GEMINI_API_KEY=AIzaSyCf0xBNnHltICzW_p5Upll7hRcDSB-Q0iA
RAG_SERVICE_URL=http://localhost:8000

# Hono server port
PORT=3001

# ── Next.js Frontend ────────────────────────────────────────
# These are exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_RAG_URL=http://localhost:8000
NEXT_PUBLIC_WORLD_APP_ID=app_963cce5506aa7a8897060b8b948eab7b
NEXT_PUBLIC_WORLD_ACTION_ID=verify-author
