# ============================================================
# SciGate — RAG Engine (FastAPI) environment variables
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=8000

# ── LLM ───────────────────────────────────────────────────────
# Either GEMINI_API_KEY or GOOGLE_API_KEY is accepted
GEMINI_API_KEY=

# ── Supabase (server uses SERVICE_ROLE, not ANON) ─────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Blockchain (for x402 payment verification on local gate) ──
WORLD_CHAIN_RPC=https://rpc.worldchain.dev
PAY_TO_ADDRESS=

# ── Cross-service ─────────────────────────────────────────────
# Where the agent buyer hits when autonomously searching the catalog
SCIGATE_API_URL=http://127.0.0.1:3001

# ── Agent buyer keys (OPTIONAL — required only for agent mode) ────
# Leave empty to disable the autonomous agent buyer.
RAG_AGENT_PRIVATE_KEY=
RAG_AGENT_SOLANA_KEY=

# ── x402 Skill (Gemini function-calling tool for agent/full mode) ─
# Max USD the agent will auto-pay per x402 tool call (enforced at logic level).
X402_MAX_COST_USD=0.10
# Preferred blockchain network for payments.
X402_PREFERRED_NETWORK=eip155:480
# HTTP timeout in seconds for x402 tool calls.
X402_TIMEOUT_S=30
# Maximum USD the agent spends per day across all tool calls. Resets at midnight.
X402_DAILY_BUDGET_USD=5.0
