# ############################################################
# SciGate - RENDER (Backend) ENVIRONMENT VARIABLES
# ############################################################

# Wallet private key for on-chain verifications (MVP)
PRIVATE_KEY=

# Wallet address that receives x402 payments (your earnings wallet)
PAY_TO_ADDRESS=

# World ID Staging App ID
WORLD_APP_ID=

# Custom action for author verification
WORLD_ACTION_ID=

# PaperRegistry contract address
PAPER_REGISTRY_ADDRESS=

# Public RAG service URL (Must be accessible from Render)
RAG_SERVICE_URL=

# Google Gemini API Key
GEMINI_API_KEY=

# Render will provide the PORT automatically
PORT=3001
